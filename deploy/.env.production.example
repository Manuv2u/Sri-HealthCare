# =============================================================================
# .env.production.example
#
# Copy this file to deploy/.env.production and fill in real values.
# deploy/.env.production is gitignored — never commit real secrets.
#
# The setup-server.sh script auto-generates a filled .env on the VM at
# /opt/sri-diagnostics/.env — you can copy it back:
#   scp -i ~/.ssh/oci_key ubuntu@<IP>:/opt/sri-diagnostics/.env deploy/.env.production
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Backend container reaches host Postgres via host.docker.internal
DATABASE_URL=postgresql+asyncpg://sri_user:CHANGE_ME@host.docker.internal:5432/sri_diagnostics
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=sri_diagnostics
DB_USER=sri_user
DB_PASSWORD=CHANGE_ME

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_48

# ── File Storage ──────────────────────────────────────────────────────────────
FILE_STORAGE_BACKEND=local
FILE_STORAGE_PATH=/app/file_storage

# AWS S3 (optional — only if FILE_STORAGE_BACKEND=s3)
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_S3_BUCKET=
#AWS_REGION=ap-south-1

# ── Payments ──────────────────────────────────────────────────────────────────
PAYMENT_WEBHOOK_SECRET=CHANGE_ME_USE_openssl_rand_base64_32

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=CHANGE_ME

# ── SMS ───────────────────────────────────────────────────────────────────────
SMS_PROVIDER=msg91
SMS_API_KEY=CHANGE_ME

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
GST_RATE=0.18
ENV_PROFILE=production
