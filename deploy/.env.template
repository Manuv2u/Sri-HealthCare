# =============================================================================
# .env.template — Sri Diagnostics Environment Variables
# Copy to .env and fill in all values before deploying
# NEVER commit .env to git
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Uses Docker service name — do NOT use localhost or an IP
DATABASE_URL=postgresql+asyncpg://sri_user:CHANGE_ME@postgres:5432/sri_diagnostics
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sri_diagnostics
DB_USER=sri_user
DB_PASSWORD=CHANGE_ME

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_64_CHARS_MINIMUM

# ── File Storage ──────────────────────────────────────────────────────────────
FILE_STORAGE_BACKEND=local
FILE_STORAGE_PATH=/app/file_storage

# ── Payments ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
PAYMENT_WEBHOOK_SECRET=CHANGE_ME

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourlab.com
SMTP_PASSWORD=CHANGE_ME

# ── SMS (MSG91) ───────────────────────────────────────────────────────────────
SMS_PROVIDER=msg91
SMS_API_KEY=CHANGE_ME

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
GST_RATE=0.18
ENV_PROFILE=production
